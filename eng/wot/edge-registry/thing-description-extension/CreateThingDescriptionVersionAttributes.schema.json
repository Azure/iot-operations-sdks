{
    "$schema": "https://json-schema.org/draft-07/schema",
    "title": "CreateThingDescriptionVersionAttributes",
    "description": "Request payload for creating a Thing Description version.",
    "type": "object",
    "additionalProperties": false,
    "required": ["labels", "thingDescriptionDocument", "thingDescriptionLabels"],
    "properties": {
        "groupId": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "documentation": {
            "type": "string"
        },
        "labels": {
            "description": "Queryable Key Value pairs to be added to the Version",
            "type": "array",
            "items": {
                "type": "object",
                "$ref": "../core-xregistry/Label.schema.json"
            }
        },
        "ancestor": {
            "description": "The versionId of this version's ancestor if it has an ancestor.",
            "type": "string"
        },
        "contentType": {
            "description": "Content type of the thing description version.",
            "type": "string"
        },
        "format": {
            "description": "Thing description format identifier, e.g. `WoT-TD/1.1`.",
            "type": "string"
        },
        "thingDescriptionDocument": {
            "type": "string",
            "description": "Base64-encoded thing description document content.",
            "contentEncoding": "base64"
        },
        "thingDescriptionLabels": {
            "description": "Queryable Key Value pairs to be added to the parent Thing Description",
            "type": "array",
            "items": {
                "type": "object",
                "$ref": "../core-xregistry/Label.schema.json"
            }
        }
    }
}

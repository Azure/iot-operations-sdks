{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        {
            "dov": "http://azure.com/DigitalTwins/dtmi#"
        }
    ],
    "@type": "tm:ThingModel",
    "title": "EdgeRegistryThingDescriptionExtensions",
    "description": "Companion type definitions for the xRegistry Thing Description entity type. Provides typed thing description definitions for SDK codegen targeting thing description Groups, thing description metadata, and thing description Versions.",
    "links": [
        {
            "rel": "tm:extends",
            "href": "./EdgeRegistry.TM.json#title=EdgeRegistry",
            "type": "application/tm+json"
        }
    ],
    "actions": {
        "getThingDescriptionVersion": {
            "description": "Retrieve an xRegistry Thing Description Version entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "versionId": {
                        "description": "Version identifier. Returns the default Version if not specified.",
                        "type": "integer"
                    }
                },
                "required": []
            },
            "output": {
                "description": "The Thing Description Version entity.",
                "dov:ref": "./thing-description-extension/ThingDescriptionVersion.schema.json"
            },
            "forms": [
                {
                    "dov:topic": "aio/registry/thingDescriptionExtension/get/thingdescriptiongroups/thingdescriptions/{ex:thingDescriptionId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingDescriptionExtensionError"
                        }
                    ]
                }
            ]
        },
        "createThingDescriptionVersion": {
            "description": "Create a new xRegistry Thing Description Version entity under the specified thing description. Returns the created Version entity with epoch=1. Create is strictly idempotent: if every field matches the latest Version of the parent Thing Description (including labels), the latest Version is returned unchanged; otherwise a new Version is created.",
            "input": {
                "description": "Attributes needed to create a Thing Description Version.",
                "dov:ref": "./thing-description-extension/CreateThingDescriptionVersionAttributes.schema.json"
            },
            "output": {
                "description": "The Thing Description Version entity.",
                "dov:ref": "./thing-description-extension/ThingDescriptionVersion.schema.json"
            },
            "forms": [
                {
                    "dov:topic": "aio/registry/thingDescriptionExtension/create/thingdescriptiongroups/thingdescriptions/{ex:thingDescriptionId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingDescriptionExtensionError"
                        }
                    ]
                }
            ]
        },
        "listThingDescriptionVersions": {
            "description": "List all Version IDs for a Thing Description.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    }
                },
                "required": []
            },
            "output": {
                "description": "List of Version identifiers.",
                "type": "object",
                "properties": {
                    "ids": {
                        "description": "List of Version identifiers.",
                        "type": "array",
                        "items": {
                            "description": "Version identifier.",
                            "type": "integer"
                        }
                    }
                },
                "required": [
                    "ids"
                ]
            },
            "forms": [
                {
                    "dov:topic": "aio/registry/thingDescriptionExtension/list/thingdescriptiongroups/thingdescriptions/{ex:thingDescriptionId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingDescriptionExtensionError"
                        }
                    ]
                }
            ]
        },
        "listThingDescriptionVersionsWithLabel": {
            "description": "List Thing Description Versions that have the specified label.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified. Ignored if allGroups is true.",
                        "type": "string"
                    },
                    "allGroups": {
                        "description": "If true, lists Versions across all Groups (groupId is ignored). If false or unspecified, lists within the Group specified by groupId, or the default Group if groupId is unspecified.",
                        "type": "boolean"
                    },
                    "thingDescriptionId": {
                        "description": "Thing Description Resource identifier. Lists Versions across all Thing Descriptions if not specified.",
                        "type": "string"
                    },
                    "labelKey": {
                        "description": "Label key.",
                        "type": "string"
                    },
                    "labelValue": {
                        "description": "Label value.",
                        "type": "string"
                    }
                },
                "required": [
                    "labelKey",
                    "labelValue"
                ]
            },
            "output": {
                "description": "List of Version XIDs within provided constraints with the specified label.",
                "type": "object",
                "properties": {
                    "versions": {
                        "description": "List of Version XID components.",
                        "type": "array",
                        "items": {
                            "description": "The XID of a Version that has the specified label.",
                            "type": "object",
                            "title": "VersionXId",
                            "required": [
                                "groupType",
                                "groupId",
                                "resourceType",
                                "resourceId",
                                "versionId"
                            ],
                            "properties": {
                                "groupType": {
                                    "description": "Group type.",
                                    "type": "string"
                                },
                                "groupId": {
                                    "description": "Group identifier.",
                                    "type": "string"
                                },
                                "resourceType": {
                                    "description": "Resource type.",
                                    "type": "string"
                                },
                                "resourceId": {
                                    "description": "Resource identifier.",
                                    "type": "string"
                                },
                                "versionId": {
                                    "description": "Version identifier.",
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "versions"
                ]
            },
            "forms": [
                {
                    "dov:topic": "aio/registry/thingDescriptionExtension/listWithLabel/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingDescriptionExtensionError"
                        }
                    ]
                }
            ]
        },
        "deleteThingDescriptionVersion": {
            "description": "Delete an xRegistry Thing Description Version entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    }
                },
                "required": []
            },
            "forms": [
                {
                    "dov:topic": "aio/registry/thingDescriptionExtension/delete/thingdescriptiongroups/thingdescriptions/{ex:thingDescriptionId}/versions/{ex:versionId}",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingDescriptionExtensionError"
                        }
                    ]
                }
            ]
        }
    },
    "schemaDefinitions": {
        "ThingDescriptionFormat": {
            "type": "object",
            "const": {
                "JsonLD11": "JSON-LD/1.1"
            },
            "description": "Non-exhaustive supported WoT TD formats",
            "properties": {
                "JsonLD11": {
                    "description": "JSON-LD 1.1 format",
                    "type": "string"
                }
            }
        },
        "ThingDescriptionGroupType": {
            "type": "string",
            "const": "thingdescriptiongroups",
            "description": "Group type used in XID for xRegistry Thing Description Groups."
        },
        "ThingDescriptionResourceType": {
            "type": "string",
            "const": "thingdescriptions",
            "description": "Resource type used in XID for xRegistry Thing Description Resources."
        },
        "ThingDescriptionExtensionError": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "URI identifying the error type."
                },
                "code": {
                    "type": "integer",
                    "description": "HTTP-style response code."
                },
                "status": {
                    "type": "string",
                    "description": "HTTP-style response status text."
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable error title."
                },
                "detail": {
                    "type": "string",
                    "description": "Detailed error description."
                },
                "subject": {
                    "type": "string",
                    "description": "The XID of the entity being processed when the error occurred, if applicable."
                },
                "source": {
                    "type": "string",
                    "description": "The component that raised the error."
                }
            },
            "required": [
                "type",
                "status",
                "code",
                "title"
            ]
        }
    }
}
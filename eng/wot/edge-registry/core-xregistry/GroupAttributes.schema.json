{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "GroupAttributes",
  "description": "Request payload for creating or updating a Group.",
  "type": "object",
  "additionalProperties": false,
  "required": ["groupType", "labels", "extensions"],
  "properties": {
      "groupType": {
          "type": "string"
      },
      "groupId": {
          "type": "string"
      },
      "name": {
          "type": "string"
      },
      "description": {
          "type": "string"
      },
      "documentation": {
          "type": "string"
      },
      "labels": {
          "type": "array",
          "items": {
              "type": "object",
              "$ref": "Label.schema.json"
          }
      },
      "extensions": {
        "description": "Extension-specific attributes (e.g., `envelope`, `protocol` for message groups).",
        "type": "object", "additionalProperties": { "type": "string", 
        "contentEncoding": "base64" }
      }
    }
}

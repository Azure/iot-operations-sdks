{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "ResourceMetaAttributes",
  "type": "object",
  "additionalProperties": false,
  "required": [ "id", "extensions", "labels" ],
  "properties": {
    "extensions": {
      "description": "Extension-specific attributes (e.g., `format` and `content_type` for schemas).",
      "type": "object", "additionalProperties": { "type": "string", 
      "contentEncoding": "base64" }
    },
    "labels": {
      "description": "The 'labels' Field.",
      "type": "array",
      "items": {
          "type": "object",
          "$ref": "Label.schema.json"
      }
    },
    "id": {
      "description": "Resource identifier within the group.",
      "type": "string"
    }
  }
}

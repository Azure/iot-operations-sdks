{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "CreateVersionRequest",
  "description": "Request payload for creating a version.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "description": "The 'createdAt' Field.",
      "type": "string", "format": "date-time"
    },
    "description": {
      "description": "The 'description' Field.",
      "type": "string"
    },
    "documentation": {
      "description": "The 'documentation' Field.",
      "type": "string"
    },
    "extensions": {
      "description": "Extension-specific attributes.",
      "type": "object", "additionalProperties": { "type": "string", 
      "contentEncoding": "base64" }
    },
    "labels": {
      "description": "The 'labels' Field.",
      "type": "object", "additionalProperties": { "type": "string" }
    },
    "name": {
      "description": "The 'name' Field.",
      "type": "string"
    },
    "versionId": {
      "description": "Version identifier.",
      "type": "string"
    }
  }
}

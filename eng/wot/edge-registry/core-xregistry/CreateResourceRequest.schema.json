{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "CreateResourceRequest",
  "description": "Request payload for creating a resource with an initial version.",
  "type": "object",
  "additionalProperties": false,
  "required": [ "defaultVersion" ],
  "properties": {
    "createdAt": {
      "description": "The 'createdAt' Field.",
      "type": "string", "format": "date-time"
    },
    "defaultVersion": {
      "description": "Request payload for creating a version.",
      "$ref": "CreateVersionRequest.schema.json"
    },
    "metaExtensions": {
      "description": "Extension-specific attributes (e.g., `format` and `content_type` for schemas).",
      "type": "object", "additionalProperties": { "type": "string", 
      "contentEncoding": "base64" }
    },
    "resourceExtensions": {
      "description": "Extension-specific attributes (e.g., `format` and `content_type` for schemas).",
      "type": "object", "additionalProperties": { "type": "string", 
      "contentEncoding": "base64" }
    }
  }
}

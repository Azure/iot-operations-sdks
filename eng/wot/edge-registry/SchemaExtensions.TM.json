{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        {
            "dtv": "http://azure.com/DigitalTwins/dtmi#"
        }
    ],
    "@type": "tm:ThingModel",
    "title": "EdgeRegistrySchemaExtensions",
    "description": "Companion type definitions for the xRegistry Schema entity type. Provides typed schema definitions for SDK codegen targeting schema Groups, schema metadata, and schema Versions.",
    "links": [
        {
            "rel": "tm:extends",
            "href": "./EdgeRegistry.TM.json#title=EdgeRegistry",
            "type": "application/tm+json"
        }
    ],
    "actions": {
        "getSchemaVersion": {
            "description": "Retrieve an xRegistry Schema Version entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "versionId": {
                        "description": "Version identifier. Returns the default Version if not specified.",
                        "type": "integer"
                    }
                },
                "required": []
            },
            "output": {
                "description": "The Schema Version entity.",
                "dtv:ref": "./schema-extension/SchemaVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/get/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "createSchemaVersion": {
            "description": "Create a new xRegistry Schema Version entity under the specified schema. Returns the created Version entity with epoch=1. Create is strictly idempotent: if every field matches the latest Version of the parent Schema (including labels), the latest Version is returned unchanged; otherwise a new Version is created.",
            "input": {
                "description": "Attributes needed to create a Schema Version.",
                "dtv:ref": "./schema-extension/CreateSchemaVersionAttributes.schema.json"
            },
            "output": {
                "description": "The Schema Version entity.",
                "dtv:ref": "./schema-extension/SchemaVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/create/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "listSchemaVersions": {
            "description": "List all Version IDs for a Schema.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    }
                },
                "required": []
            },
            "output": {
                "description": "List of Version identifiers.",
                "type": "object",
                "properties": {
                    "ids": {
                        "description": "List of Version identifiers.",
                        "type": "array",
                        "items": {
                            "description": "Version identifier.",
                            "type": "integer"
                        }
                    }
                },
                "required": [
                    "ids"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/list/schemagroups/schemas/{ex:schemaId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "listSchemaVersionsWithLabel": {
            "description": "List Schema Version IDs for a Schema, filtered by a label match.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "labelKey": {
                        "description": "Label key.",
                        "type": "string"
                    },
                    "labelValue": {
                        "description": "Label value.",
                        "type": "string"
                    }
                },
                "required": [
                    "labelKey",
                    "labelValue"
                ]
            },
            "output": {
                "description": "List of Version identifiers.",
                "type": "object",
                "properties": {
                    "ids": {
                        "description": "List of Version identifiers.",
                        "type": "array",
                        "items": {
                            "description": "Version identifier.",
                            "type": "integer"
                        }
                    }
                },
                "required": [
                    "ids"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/listWithLabel/schemagroups/schemas/{ex:schemaId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "deleteSchemaVersion": {
            "description": "Delete an xRegistry Schema Version entity. [ASK: behavior when deleting the default Version \u2014 promote next-most-recent, or error?]",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "versionId": {
                        "description": "Version identifier.",
                        "type": "integer"
                    }
                },
                "required": [
                    "versionId"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/delete/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        }
    },
    "schemaDefinitions": {
        "SchemaFormat": {
            "type": "object",
            "const": {
                "JsonSchemaDraft07": "JsonSchema/draft-07",
                "Avro1110": "Avro/1.11.0"
            },
            "description": "Non-exhaustive supported schema formats",
            "properties": {
                "JsonSchemaDraft07": {
                    "description": "JSON Schema Draft-07 format",
                    "type": "string"
                },
                "Avro1110": {
                    "description": "Avro 1.11.0 format",
                    "type": "string"
                }
            }
        },
        "SchemaGroupType": {
            "type": "string",
            "const": "schemagroups",
            "description": "Group type used in xId for xRegistry Schema Groups."
        },
        "SchemaResourceType": {
            "type": "string",
            "const": "schemas",
            "description": "Resource type used in xId for xRegistry Schema Resources."
        },
        "SchemaExtensionError": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "URI identifying the error type."
                },
                "code": {
                    "type": "integer",
                    "description": "HTTP-style response code."
                },
                "status": {
                    "type": "string",
                    "description": "HTTP-style response status text."
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable error title."
                },
                "detail": {
                    "type": "string",
                    "description": "Detailed error description."
                },
                "instance": {
                    "type": "string",
                    "description": "The XID of the entity that caused the error."
                }
            },
            "required": [
                "type",
                "status",
                "code",
                "title",
                "instance"
            ]
        }
    }
}

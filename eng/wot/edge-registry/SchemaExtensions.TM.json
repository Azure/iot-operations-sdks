{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        { "dtv": "http://azure.com/DigitalTwins/dtmi#" }
    ],
    "@type": "tm:ThingModel",
    "title": "EdgeRegistrySchemaExtensions",
    "description": "Companion type definitions for the xRegistry Schema entity type. Provides typed schema definitions for SDK codegen targeting schema groups, schema metadata, and schema versions.",
    "links" : [{
        "rel": "tm:extends",
        "href": "./EdgeRegistry.TM.json#title=EdgeRegistry",
        "type": "application/tm+json"
    }],
    "actions": {
        "getSchemaVersion": {
            "description": "Retrieve an xRegistry Schema Version entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    },
                    "versionId": {
                        "type": "integer"
                    }
                },
                "required": [ ]
            },
            "output": {
                "dtv:ref": "./schema-extension/SchemaVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/get/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "createSchemaVersion": {
            "description": "Create a new xRegistry Schema Version entity under the specified schema. Returns the created version entity with epoch=1.",
            "input": {
                "dtv:ref": "./schema-extension/CreateSchemaVersionAttributes.schema.json"
            },
            "output": {
                "dtv:ref": "./schema-extension/SchemaVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/create/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "createOrGetSchemaVersion": {
            "description": "Create a new xRegistry Schema Version entity under the specified schema if the document doesn't already exist as a current version. Returns the created version entity or the most recent matching version entity.",
            "input": {
                "dtv:ref": "./schema-extension/CreateSchemaVersionAttributes.schema.json"
            },
            "output": {
                "dtv:ref": "./schema-extension/SchemaVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/createOrGet/schemagroups/schemas/{ex:schemaId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        },
        "listSchemaVersions": {
            "description": "List all Version IDs for a given Schema entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "type": "object",
                "properties": {
                    "ids": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        }
                    }
                },
                "required": ["ids"]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/schemaExtension/list/schemagroups/schemas/{ex:schemaId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "SchemaExtensionError"
                        }
                    ]
                }
            ]
        }
    },
    "schemaDefinitions": {
        "SchemaFormat": {
            "type": "object",
            "const": {
                "JsonSchemaDraft07": "JsonSchema/draft-07",
                "Avro1110": "Avro/1.11.0"
            },
            "description": "Non-exhaustive supported schema formats",
            "properties": {
                "JsonSchemaDraft07": {
                    "description": "JSON Schema Draft-07 format",
                    "type": "string"
                },
                "Avro1110": {
                    "description": "Avro 1.11.0 format",
                    "type": "string"
                }
            }
        },
        "SchemaGroupType": {
            "type": "string",
            "const": "schemagroups",
            "description": "Group type used in xId for xRegistry Schema groups."
        },
        "SchemaResourceType": {
            "type": "string",
            "const": "schemas",
            "description": "Resource type used in xId for xRegistry Schema resources."
        },
        "SchemaExtensionError": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "URI identifying the error type."
                },
                "code": {
                    "type": "integer",
                    "description": "HTTP-style response code."
                },
                "status": {
                    "type": "string",
                    "description": "HTTP-style response status text."
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable error title."
                },
                "detail": {
                    "type": "string",
                    "description": "Detailed error description."
                },
                "instance": {
                    "type": "string",
                    "description": "The XID of the entity that caused the error."
                }
            },
            "required": ["type", "status", "code", "title", "instance"]
        }
    }
}

{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        { "dtv": "http://azure.com/DigitalTwins/dtmi#" }
    ],
    "@type": "tm:ThingModel",
    "title": "EdgeRegistry",
    "description": "Generic xRegistry CRUD service — provides create, get, delete, and list operations on xRegistry entities (groups, resources, versions) identified by XID paths.",
    "actions": {
        "createGroup": {
            "description": "Create a new xRegistry Group. Returns the created Group with epoch=1.",
            "input": {
                "dtv:ref": "./core-xregistry/GroupAttributes.schema.json"
            },
            "output": {
                "dtv:ref": "./core-xregistry/Group.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/create/{ex:groupType}/group",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "getGroup": {
            "description": "Retrieve an xRegistry Group entity by XID path.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "dtv:ref": "./core-xregistry/Group.schema.json",
                "description": "The group entity."
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/get/{ex:groupType}/group",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "getResource": {
            "description": "Retrieve an xRegistry Resource entity by XID path.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "dtv:ref": "./core-xregistry/Resource.schema.json",
                "description": "The resource entity."
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/get/{ex:groupType}/{ex:resourceType}/{ex:resourceId}",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "getVersion": {
            "description": "Retrieve an xRegistry Version entity by XID path.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "dtv:ref": "./core-xregistry/Version.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/get/{ex:groupType}/{ex:resourceType}/{ex:resourceId}/versions/{ex:versionId}",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "listGroups": {
            "description": "List xRegistry groups of a specific type.",
            "output": {
                "type": "object",
                "properties": {
                    "ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["ids"]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/list/{ex:groupType}",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "listResources": {
            "description": "List xRegistry resources of a specific type on a group.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "type": "object",
                "properties": {
                    "ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["ids"]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/list/{ex:groupType}/{ex:resourceType}",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "listResourcesWithLabel": {
            "description": "List xRegistry resources that have the specified label.",
            "input": {
                "type": "object",
                "properties": {
                    "groupType": {
                        "type": "string"
                    },
                    "groupId": {
                        "type": "string"
                    },
                    "resourceType": {
                        "type": "string"
                    },
                    "labelKey": {
                        "type": "string"
                    },
                    "labelValue": {
                        "type": "string"
                    }
                },
                "required": ["labelKey", "labelValue"]
            },
            "output": {
                "type": "object",
                "properties": {
                    "resources": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "title": "ResourceXId",
                            "required": ["groupType", "groupId", "resourceType", "resourceId"],
                            "properties": {
                                "groupType": {
                                    "type": "string"
                                },
                                "groupId": {
                                    "type": "string"
                                },
                                "resourceType": {
                                    "type": "string"
                                },
                                "resourceId": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "required": ["resources"]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/listWithLabel/resources",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        },
        "listVersions": {
            "description": "List xRegistry versions for a Resource.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "type": "string"
                    }
                },
                "required": [ ]
            },
            "output": {
                "type": "object",
                "properties": {
                    "ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["ids"]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/list/{ex:groupType}/{ex:resourceType}/{ex:resourceId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "EdgeRegistryError"
                        }
                    ]
                }
            ]
        }
    },
    "schemaDefinitions": {
        "EdgeRegistryError": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "URI identifying the error type."
                },
                "code": {
                    "type": "integer",
                    "description": "HTTP-style response code."
                },
                "status": {
                    "type": "string",
                    "description": "HTTP-style response status text."
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable error title."
                },
                "detail": {
                    "type": "string",
                    "description": "Detailed error description."
                },
                "instance": {
                    "type": "string",
                    "description": "The XID of the entity that caused the error."
                }
            },
            "required": ["type", "status", "code", "title", "instance"]
        }
    }
}

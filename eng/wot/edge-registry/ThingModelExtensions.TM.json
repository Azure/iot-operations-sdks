{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        {
            "dtv": "http://azure.com/DigitalTwins/dtmi#"
        }
    ],
    "@type": "tm:ThingModel",
    "title": "EdgeRegistryThingModelExtensions",
    "description": "Companion type definitions for the xRegistry Thing Model entity type. Provides typed thing model definitions for SDK codegen targeting thing model Groups, thing model metadata, and thing model Versions.",
    "links": [
        {
            "rel": "tm:extends",
            "href": "./EdgeRegistry.TM.json#title=EdgeRegistry",
            "type": "application/tm+json"
        }
    ],
    "actions": {
        "getThingModelVersion": {
            "description": "Retrieve an xRegistry Thing Model Version entity.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "versionId": {
                        "description": "Version identifier. Returns the default Version if not specified.",
                        "type": "integer"
                    }
                },
                "required": []
            },
            "output": {
                "description": "The Thing Model Version entity.",
                "dtv:ref": "./thing-model-extension/ThingModelVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/thingModelExtension/get/thingmodelgroups/thingmodels/{ex:thingModelId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingModelExtensionError"
                        }
                    ]
                }
            ]
        },
        "createThingModelVersion": {
            "description": "Create a new xRegistry Thing Model Version entity under the specified thing model. Returns the created Version entity with epoch=1. Create is strictly idempotent: if every field matches the latest Version of the parent Thing Model (including labels), the latest Version is returned unchanged; otherwise a new Version is created.",
            "input": {
                "description": "Attributes needed to create a Thing Model Version.",
                "dtv:ref": "./thing-model-extension/CreateThingModelVersionAttributes.schema.json"
            },
            "output": {
                "description": "The Thing Model Version entity.",
                "dtv:ref": "./thing-model-extension/ThingModelVersion.schema.json"
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/thingModelExtension/create/thingmodelgroups/thingmodels/{ex:thingModelId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingModelExtensionError"
                        }
                    ]
                }
            ]
        },
        "listThingModelVersions": {
            "description": "List all Version IDs for a Thing Model.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    }
                },
                "required": []
            },
            "output": {
                "description": "List of Version identifiers.",
                "type": "object",
                "properties": {
                    "ids": {
                        "description": "List of Version identifiers.",
                        "type": "array",
                        "items": {
                            "description": "Version identifier.",
                            "type": "integer"
                        }
                    }
                },
                "required": [
                    "ids"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/thingModelExtension/list/thingmodelgroups/thingmodels/{ex:thingModelId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingModelExtensionError"
                        }
                    ]
                }
            ]
        },
        "listThingModelVersionsWithLabel": {
            "description": "List Thing Model Version IDs for a Thing Model, filtered by a label match.",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "labelKey": {
                        "description": "Label key.",
                        "type": "string"
                    },
                    "labelValue": {
                        "description": "Label value.",
                        "type": "string"
                    }
                },
                "required": [
                    "labelKey",
                    "labelValue"
                ]
            },
            "output": {
                "description": "List of Version identifiers.",
                "type": "object",
                "properties": {
                    "ids": {
                        "description": "List of Version identifiers.",
                        "type": "array",
                        "items": {
                            "description": "Version identifier.",
                            "type": "integer"
                        }
                    }
                },
                "required": [
                    "ids"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/thingModelExtension/listWithLabel/thingmodelgroups/thingmodels/{ex:thingModelId}/versions",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingModelExtensionError"
                        }
                    ]
                }
            ]
        },
        "deleteThingModelVersion": {
            "description": "Delete an xRegistry Thing Model Version entity. [ASK: behavior when deleting the default Version \u2014 promote next-most-recent, or error?]",
            "input": {
                "type": "object",
                "properties": {
                    "groupId": {
                        "description": "Group identifier. Uses the default if not specified.",
                        "type": "string"
                    },
                    "versionId": {
                        "description": "Version identifier.",
                        "type": "integer"
                    }
                },
                "required": [
                    "versionId"
                ]
            },
            "forms": [
                {
                    "dtv:topic": "aio/registry/thingModelExtension/delete/thingmodelgroups/thingmodels/{ex:thingModelId}/versions/version",
                    "contentType": "application/json",
                    "op": "invokeaction",
                    "additionalResponses": [
                        {
                            "success": false,
                            "schema": "ThingModelExtensionError"
                        }
                    ]
                }
            ]
        }
    },
    "schemaDefinitions": {
        "ThingModelFormat": {
            "type": "object",
            "const": {
                "WotTM11": "WoT-TM/1.1"
            },
            "description": "Non-exhaustive supported WoT TM formats",
            "properties": {
                "WotTM11": {
                    "description": "WoT TM 1.1 format",
                    "type": "string"
                }
            }
        },
        "ThingModelGroupType": {
            "type": "string",
            "const": "thingmodelgroups",
            "description": "Group type used in XID for xRegistry Thing Model Groups."
        },
        "ThingModelResourceType": {
            "type": "string",
            "const": "thingmodels",
            "description": "Resource type used in XID for xRegistry Thing Model Resources."
        },
        "ThingModelExtensionError": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "URI identifying the error type."
                },
                "code": {
                    "type": "integer",
                    "description": "HTTP-style response code."
                },
                "status": {
                    "type": "string",
                    "description": "HTTP-style response status text."
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable error title."
                },
                "detail": {
                    "type": "string",
                    "description": "Detailed error description."
                },
                "instance": {
                    "type": "string",
                    "description": "The XID of the entity that caused the error."
                }
            },
            "required": [
                "type",
                "status",
                "code",
                "title",
                "instance"
            ]
        }
    }
}

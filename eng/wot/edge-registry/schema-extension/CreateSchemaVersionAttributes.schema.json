{
    "$schema": "https://json-schema.org/draft-07/schema",
    "title": "CreateSchemaVersionAttributes",
    "description": "Request payload for creating a Schema version.",
    "type": "object",
    "additionalProperties": false,
    "required": ["groupId", "schemaId", "labels", "schemaDocument"],
    "properties": {
        "groupId": {
            "type": "string"
        },
        "schemaId": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "documentation": {
            "type": "string"
        },
        "labels": {
            "type": "object", "additionalProperties": { "type": "string" }
        },
        "ancestor": {
            "description": "The versionId of this version's ancestor if it has an ancestor.",
            "type": "integer"
        },
        "contentType": {
            "description": "Content type of the schema version.",
            "type": "string"
        },
        "format": {
            "description": "Schema format identifier, e.g. `JsonSchema/draft-07`, `Protobuf/3`.",
            "type": "string"
        },
        "schemaDocument": {
            "type": "string",
            "description": "Base64-encoded schema document content.",
            "contentEncoding": "base64"
        }
    }
}

{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "SchemaVersion",
  "description": "A specific version of a schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [ "extensions", "version"],
  "properties": {
    "version": {
      "description": "The generic version entity.",
      "$ref": "../core-xregistry/Version.schema.json"
    },
    "extensions": {
      "description": "Additional fields and field guarantees for the schema extension.",
      "$ref": "SchemaVersionExtensions.schema.json"
    }
  }
}

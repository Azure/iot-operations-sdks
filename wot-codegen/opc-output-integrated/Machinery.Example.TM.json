        "contentType": "application/json",
        "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/properties/read",
        "op": "readallproperties"
      }
    ],
    "tm:optional": [
      "/properties/AssetId",
      "/properties/ComponentName",
      "/properties/DefaultInstanceBrowseName",
      "/properties/DeviceClass",
      "/properties/HardwareRevision",
      "/properties/InitialOperationDate",
      "/properties/ManufacturerUri",
      "/properties/Model",
      "/properties/MonthOfConstruction",
      "/properties/ProductCode",
      "/properties/ProductInstanceUri",
      "/properties/SoftwareRevision",
      "/properties/YearOfConstruction"
    ],
    "actions": {
    },
    "properties": {
      "AssetId": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "To be used by end users to store a unique identification in the context of their overall application. Servers shall support at least 40 Unicode characters for the clients writing this value, this means clients can expect to be able to write strings with a length of 40 Unicode characters into that field.",
        "type": "string",
        "readOnly": false,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/AssetId/write",
            "op": "writeproperty"
          },
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/AssetId/read",
            "op": "readproperty"
          }
        ]
      },
      "ComponentName": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "To be used by end users to store a human-readable localized text for the MachineryItem. The minimum number of locales supported for this property shall be two. Servers shall support at least 40 Unicode characters for the clients writing the text part of each locale, this means clients can expect to be able to write texts with a length of 40 Unicode characters into that field.",
        "type": "string",
        "readOnly": false,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/ComponentName/write",
            "op": "writeproperty"
          },
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/ComponentName/read",
            "op": "readproperty"
          }
        ]
      },
      "DefaultInstanceBrowseName": {
        "description": "The default BrowseName for instances of the type.",
        "type": "string",
        "readOnly": false,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/DefaultInstanceBrowseName/write",
            "op": "writeproperty"
          },
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/DefaultInstanceBrowseName/read",
            "op": "readproperty"
          }
        ]
      },
      "DeviceClass": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "Indicates in which domain or for what purpose the MachineryItem is used.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/DeviceClass/read",
            "op": "readproperty"
          }
        ]
      },
      "HardwareRevision": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A string representation of the revision level of the hardware of a MachineryItem. Hardware is physical equipment, as opposed to programs, procedures, rules and associated documentation. Many machines will not provide such information due to the modular and configurable nature of the machine.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/HardwareRevision/read",
            "op": "readproperty"
          }
        ]
      },
      "InitialOperationDate": {
        "dov:namespace": "http://opcfoundation.org/UA/Machinery/",
        "description": "The date, when the MachineryItem was switched on the first time after it has left the manufacturer plant.",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/InitialOperationDate/read",
            "op": "readproperty"
          }
        ]
      },
      "Manufacturer": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A human-readable, localized name of the manufacturer of the MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/Manufacturer/read",
            "op": "readproperty"
          }
        ]
      },
      "ManufacturerUri": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A globally unique identifier of the manufacturer of the MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/ManufacturerUri/read",
            "op": "readproperty"
          }
        ]
      },
      "Model": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A human-readable, localized name of the model of the MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/Model/read",
            "op": "readproperty"
          }
        ]
      },
      "MonthOfConstruction": {
        "dov:namespace": "http://opcfoundation.org/UA/Machinery/",
        "description": "The month in which the manufacturing process of the MachineryItem has been completed. It shall be a number between 1 and 12, representing the month from January to December.",
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/MonthOfConstruction/read",
            "op": "readproperty"
          }
        ]
      },
      "ProductCode": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A machine-readable string of the model of the MachineryItem, that might include options like the hardware configuration of the model. This information might be provided by the ERP system of the vendor. For example, it can be used as order information.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/ProductCode/read",
            "op": "readproperty"
          }
        ]
      },
      "ProductInstanceUri": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A globally unique resource identifier provided by the manufacturer of the MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/ProductInstanceUri/read",
            "op": "readproperty"
          }
        ]
      },
      "SerialNumber": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A string containing a unique production number of the manufacturer of the MachineryItem. The global uniqueness of the serial number is only given in the context of the manufacturer, and potentially the model. The value shall not change during the life-cycle of the MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/SerialNumber/read",
            "op": "readproperty"
          }
        ]
      },
      "SoftwareRevision": {
        "dov:namespace": "http://opcfoundation.org/UA/DI/",
        "description": "A string representation of the revision level of a MachineryItem. In most cases, MachineryItems consist of several software components. In that case, information about the software components might be provided as additional information in the address space, including individual revision information. In that case, this property is either not provided or provides an overall software revision level. The value might change during the life-cycle of a MachineryItem.",
        "type": "string",
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/SoftwareRevision/read",
            "op": "readproperty"
          }
        ]
      },
      "YearOfConstruction": {
        "dov:namespace": "http://opcfoundation.org/UA/Machinery/",
        "description": "The year (Gregorian calendar) in which the manufacturing process of the MachineryItem has been completed. It shall be a four-digit number and never change during the life-cycle of a MachineryItem.",
        "type": "integer",
        "minimum": 0,
        "maximum": 65535,
        "readOnly": true,
        "forms": [
          {
            "contentType": "application/json",
            "dov:topic": "opcua/Machinery/Machinery_MachineryItemIdentificationType/property/YearOfConstruction/read",
            "op": "readproperty"
          }
        ]
      }
    },
    "events": {
    }
  },

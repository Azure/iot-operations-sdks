<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="AzureIoTOperations" value="https://pkgs.dev.azure.com/azure-iot-sdks/iot-operations/_packaging/preview/nuget/v3/index.json" />
  </packageSources>
  <!--
    Package source mapping: DTDLParser is published only to the AzureIoTOperations
    preview feed, so it is mapped there. Every other package (including DTDLParser's
    transitive dependencies) is resolved from nuget.org. This prevents NuGet from
    attempting to download common packages through the AzureIoTOperations feed's
    upstream proxy, which returns 401 for packages not yet cached in the feed.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="AzureIoTOperations">
      <package pattern="DTDLParser*" />
    </packageSource>
  </packageSourceMapping>
</configuration>

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Akri": "Debug"
    }
  },
  "HistorianConnector": {
    "ConnectorInstanceId": "smb-connector",
    "TickIntervalSeconds": 60,
    "GlobalConcurrencyLimit": 4,
    "GracefulShutdownTimeoutSeconds": 30,
    "ValidateOnStartup": true,
    "DefaultWindowDurationSeconds": 60,
    "DefaultAvailabilityDelaySeconds": 0
  },
    "SMBConnector": {
        "Host": "smb-server.local",
        "Port": 445,
        "ShareName": "HistorianData",
        "Username": "historian-reader",
        "UseKeyVault": false,
        "Password": "REPLACE_WITH_LOCAL_TEST_PASSWORD",
        "KeyVaultUrl": "https://your-keyvault.vault.azure.net/",
        "KeyVaultSecretName": "smb-password",
        "ConnectionTimeoutSeconds": 30,
        "MaxConcurrentConnections": 10,
        "MaxFileSizeBytes": 10485760,
        "EnableLeaderElection": false,
        "LeaderElectionNamespace": "default",
        "LeaderElectionLeaseName": "smb-connector-leader"
    }
}

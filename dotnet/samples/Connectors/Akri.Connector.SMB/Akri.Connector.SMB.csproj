<!-- SMB connector project for accessing SMB shares as historian data sources -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);IDE0028;IDE0055;IDE0060;IDE0052;IDE0290;IDE0301;IDE0305;CA1822;CA2000;CA2016;CA2213;CA1725</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Akri Historian Connector Core: Bridges RQR with AIO SDK -->
    <ProjectReference Include="..\..\..\src\Akri.ConnectorFramework.Authentication\Akri.ConnectorFramework.Authentication.csproj" />
    <ProjectReference Include="..\..\..\src\Akri.HistorianConnector.Core\Akri.HistorianConnector.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- SMB Protocol Support -->
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="10.0.3" />
    <PackageReference Include="SMBLibrary" Version="1.5.5.2" />



    <!-- File system globbing -->
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <None Include="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
